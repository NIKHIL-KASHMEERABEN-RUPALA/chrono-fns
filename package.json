{
  "name": "chrono-fns",
  "version": "0.1.0",
  "description": "A useful utility library",
  "keywords": ["utility", "typescript"],
  "repository": {
    "type": "git",
    "url": "https://github.com/NIKHIL-KASHMEERABEN-RUPALA/chrono-fns"
  },
  "license": "MIT",
  "author": "Nikhil_Rupala",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}